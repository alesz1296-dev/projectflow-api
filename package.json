{
  "name": "projectflow-api",
  "version": "1.0.0",
  "description": "A production-grade project management API showcasing an array of back-end development capabilities",
  "main": "dist/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/alesz1296-dev/projectflow-api.git"
  },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "docker:build": "DOCKER_BUILDKIT=1 docker build -t projectflow-api:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f api",
    "docker:test": "docker-compose exec api npm test",
    "docker:migrate": "docker-compose exec api npx prisma migrate deploy",
    "docker:reset": "docker-compose exec api npx prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "5.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.5.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.2.0",
    "prisma": "5.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
